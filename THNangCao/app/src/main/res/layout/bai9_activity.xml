<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ĐĂNG KÝ MÔN HỌC"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:textColor="@color/black"/>

        <EditText
            android:id="@+id/etStudentNameReg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Họ tên sinh viên"
            android:inputType="textPersonName"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etStudentID"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mã số sinh viên"
            android:inputType="text"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chọn môn học (500k/môn):"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <CheckBox android:id="@+id/cbCourse1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lập trình Android"/>
        <CheckBox android:id="@+id/cbCourse2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cơ sở dữ liệu"/>
        <CheckBox android:id="@+id/cbCourse3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mạng máy tính"/>
        <CheckBox android:id="@+id/cbCourse4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cấu trúc dữ liệu"/>
        <CheckBox android:id="@+id/cbCourse5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thiết kế Web"/>
        <CheckBox android:id="@+id/cbCourse6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trí tuệ nhân tạo"/>

        <Button
            android:id="@+id/btnCalculateTuition"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TÍNH HỌC PHÍ"
            android:layout_marginTop="24dp"
            android:backgroundTint="#673AB7"/>

        <Button
            android:id="@+id/btnResetForm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LÀM MỚI"
            android:backgroundTint="#9E9E9E"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tvTuitionResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:padding="12dp"
            android:layout_marginTop="24dp"
            android:background="#E1F5FE"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>