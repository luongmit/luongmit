<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DANH SÁCH BÀI TẬP"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp"
            android:textColor="@color/black"/>

        <Button android:id="@+id/btnBai1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="BÀI 1: Đăng ký tài khoản" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btnBai2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="BÀI 2: Quản lý sinh viên" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btnBai3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="BÀI 3: Đặt vé xem phim" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btnBai4" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="BÀI 4: Tính lương nhân viên" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btnBai5" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="BÀI 5: Trắc nghiệm 5 câu" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btnBai6" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="BÀI 6: Quản lý sản phẩm mini" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btnBai7" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="BÀI 7: Đặt phòng khách sạn" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btnBai8" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="BÀI 8: Quản lý chi tiêu" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btnBai9" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="BÀI 9: Đăng ký môn học" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btnBai10" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="BÀI 10: Bán hàng mini" android:layout_marginBottom="8dp"/>

    </LinearLayout>
</ScrollView>