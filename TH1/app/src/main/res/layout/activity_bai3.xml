<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Tiêu đề trang -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:text="DANH MỤC MÔN HỌC"
            android:textColor="#1A237E"
            android:textSize="24sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <!-- Item 1: Lập trình Android -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lập trình Android"
                    android:textColor="#1A73E8"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="60dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:background="#1A73E8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Số tín chỉ: 03"
                    android:textColor="#546E7A"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Giảng viên: ThS. Nguyễn Văn B"
                    android:textColor="#546E7A"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="8dp"
                    android:text="XEM CHI TIẾT"
                    android:textColor="#1A73E8"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Copy và thay đổi nội dung cho các Item tiếp theo để đảm bảo cân đối -->
        <!-- Item 2: Cấu trúc dữ liệu -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cấu trúc dữ liệu &amp; Giải thuật"
                    android:textColor="#E91E63"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="60dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:background="#E91E63" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Số tín chỉ: 04"
                    android:textColor="#546E7A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Giảng viên: TS. Trần Thị C"
                    android:textColor="#546E7A" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="XEM CHI TIẾT"
                    android:textColor="#E91E63" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Item 3: Cơ sở dữ liệu -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cơ sở dữ liệu" android:textColor="#2E7D32" android:textSize="20sp" android:textStyle="bold" />
                <View android:layout_width="60dp" android:layout_height="3dp" android:layout_marginTop="8dp" android:layout_marginBottom="16dp" android:background="#2E7D32" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Số tín chỉ: 03" android:textColor="#546E7A" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Giảng viên: ThS. Lê Văn D" android:textColor="#546E7A" />
                <com.google.android.material.button.MaterialButton style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end" android:text="XEM CHI TIẾT" android:textColor="#2E7D32" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Các môn tiếp theo tương tự... (Bạn có thể copy thêm 3 môn nữa từ các mẫu trên) -->
        <!-- Môn 4 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mạng máy tính" android:textColor="#FF8F00" android:textSize="20sp" android:textStyle="bold" />
                <View android:layout_width="60dp" android:layout_height="3dp" android:layout_marginTop="8dp" android:layout_marginBottom="16dp" android:background="#FF8F00" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Số tín chỉ: 03" android:textColor="#546E7A" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Giảng viên: ThS. Phạm Văn E" android:textColor="#546E7A" />
                <com.google.android.material.button.MaterialButton style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end" android:text="XEM CHI TIẾT" android:textColor="#FF8F00" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>